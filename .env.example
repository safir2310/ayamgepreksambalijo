# Database - PostgreSQL (Neon)
# Recommended for most uses
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# Parameters for constructing your own connection string
PGHOST="your-host-pooler.c-4.us-east-1.aws.neon.tech"
PGHOST_UNPOOLED="your-host.c-4.us-east-1.aws.neon.tech"
PGUSER="your_user"
PGDATABASE="your_database"
PGPASSWORD="your_password"

# Parameters for Vercel Postgres Templates
POSTGRES_URL="postgresql://user:password@host:5432/database?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database?sslmode=require"
POSTGRES_USER="your_user"
POSTGRES_HOST="your-host-pooler.c-4.us-east-1.aws.neon.tech"
POSTGRES_PASSWORD="your_password"
POSTGRES_DATABASE="your_database"
POSTGRES_URL_NO_SSL="postgresql://user:password@host:5432/database"
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/database?connect_timeout=15&sslmode=require"

# Environment
NODE_ENV="production"

# WebSocket (Optional - for development only)
# In production, use a separate WebSocket service
# WEBSOCKET_URL="http://localhost:3003"

# NextAuth (Optional - if needed in future)
# NEXTAUTH_URL="https://your-domain.com"
# NEXTAUTH_SECRET="your-secret-key"

# Custom Configuration
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
